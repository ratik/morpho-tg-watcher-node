{
  "name": "morpho-tg-watcher-node",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram alert bot for Morpho vault liquidity thresholds",
  "type": "module",
  "engines": {
    "node": ">=22.22.2"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "get_vaults": "tsx src/scripts/get-vaults.ts",
    "poll_metrics": "tsx src/scripts/poll-metrics.ts",
    "poll_metrics:once": "tsx src/scripts/poll-metrics.ts --once",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@morpho-org/morpho-ts": "^2.2.1",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.6.1",
    "grammy": "^1.36.1",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "toml": "^3.0.0",
    "undici": "^7.8.0",
    "viem": "^2.29.4",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
